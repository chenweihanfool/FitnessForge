# Copy this to `.env` (git-ignored) in the same directory as docker-compose.yml
# and fill in real values. docker-compose reads .env automatically for the
# ${VAR} substitutions in docker-compose.yml.

# ── 資料庫 ─────────────────────────────────────────────────────────────────
# 指向既有的 Postgres 實例（跟 tasktracker/pf-cwh 共用，不是這個 repo 的
# docker-compose 自己管理的 container）。如果那個 Postgres 是直接跑在 Docker
# 主機上（不在 container 裡），這裡的 host 要填 host.docker.internal，不能填
# localhost/127.0.0.1 ——app 容器裡的 localhost 是指容器自己，連不到主機。
DATABASE_URL=postgresql://user:password@host.docker.internal:5432/dbname

# ── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET=請換成一組隨機長字串

# ── Google OAuth（取代原本的 Replit Auth）──────────────────────────────────
# 到 Google Cloud Console 建立 OAuth 用戶端取得，見 docs/google-oauth-setup.md
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx

# 指定管理員的 Google 帳號 email（第一個登入者如無此設定也會成為管理員）
ADMIN_GOOGLE_EMAIL=your-email@gmail.com

# ── 其他 ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
